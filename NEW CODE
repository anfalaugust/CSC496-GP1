# ============================================================
# STEP 3 — CELL 1 (REWRITTEN): CrossAttention for feature maps
# ============================================================
# This operates on sequences of tokens (49 per branch)
# instead of flat pooled vectors.

class CrossAttention(nn.Module):
    """
    Bidirectional Cross-Attention for sequences of tokens
    derived from feature maps. Each token represents one
    spatial position from the 7x7 final feature map.
    """
    def __init__(self, dim, num_heads=8, dropout=0.1):
        super().__init__()
        self.num_heads = num_heads
        self.head_dim  = dim // num_heads
        self.scale     = self.head_dim ** -0.5

        # EfficientNet branch attends to Swin
        self.q_eff  = nn.Linear(dim, dim)
        self.k_swin = nn.Linear(dim, dim)
        self.v_swin = nn.Linear(dim, dim)

        # Swin branch attends to EfficientNet
        self.q_swin = nn.Linear(dim, dim)
        self.k_eff  = nn.Linear(dim, dim)
        self.v_eff  = nn.Linear(dim, dim)

        # Output projection (operates per token)
        self.out_proj = nn.Sequential(
            nn.Linear(dim * 2, dim * 2),
            nn.LayerNorm(dim * 2),
            nn.GELU(),
            nn.Dropout(dropout)
        )

        self.dropout = nn.Dropout(dropout)

    def attention(self, q, k, v):
        """
        Real multi-head scaled dot-product attention.
        q, k, v: (B, N, dim) where N is the number of tokens.
        returns:  (B, N, dim)
        """
        B, N, _ = q.shape
        H, D = self.num_heads, self.head_dim

        # Reshape: (B, N, dim) → (B, H, N, D)
        q = q.view(B, N, H, D).transpose(1, 2)
        k = k.view(B, N, H, D).transpose(1, 2)
        v = v.view(B, N, H, D).transpose(1, 2)

        # Attention scores: (B, H, N, N)
        attn = (q @ k.transpose(-2, -1)) * self.scale
        attn = self.dropout(torch.softmax(attn, dim=-1))

        # Weighted values: (B, H, N, D)
        out = attn @ v

        # Merge heads: (B, H, N, D) → (B, N, H*D)
        out = out.transpose(1, 2).reshape(B, N, H * D)
        return out

    def forward(self, eff_tokens, swin_tokens):
        """
        eff_tokens, swin_tokens: (B, N, dim)
        returns: (B, N, 2*dim)
        """
        # Direction 1: EfficientNet queries Swin
        eff_attended = self.attention(
            self.q_eff(eff_tokens),
            self.k_swin(swin_tokens),
            self.v_swin(swin_tokens))

        # Direction 2: Swin queries EfficientNet
        swin_attended = self.attention(
            self.q_swin(swin_tokens),
            self.k_eff(eff_tokens),
            self.v_eff(eff_tokens))

        # Concatenate along channel dim
        fused = torch.cat([eff_attended, swin_attended], dim=-1)
        return self.out_proj(fused)


