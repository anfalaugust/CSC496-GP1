# STEP 4 — CELL 3 (v2): Train & Validate Functions
# ============================================================
# Change for v2: validate() now returns per-class accuracy
# so we can spot classes being neglected during training.
# ============================================================

def train_one_epoch(model, loader, optimizer,
                    criterion, device):
    model.train()
    total_loss, correct, total = 0.0, 0, 0

    for batch_idx, (images, labels) in enumerate(loader):
        images  = images.to(device)
        labels  = labels.to(device)

        optimizer.zero_grad()
        outputs = model(images)
        loss    = criterion(outputs, labels)
        loss.backward()

        nn.utils.clip_grad_norm_(
            model.parameters(), max_norm=1.0)

        optimizer.step()

        total_loss += loss.item()
        _, predicted = outputs.max(1)
        correct += predicted.eq(labels).sum().item()
        total   += labels.size(0)

        if (batch_idx + 1) % 20 == 0:
            print(f"      Batch [{batch_idx+1}/"
                  f"{len(loader)}] "
                  f"Loss: {loss.item():.4f}")

    return total_loss / len(loader), correct / total


def validate(model, loader, criterion, device,
             num_classes=NUM_CLASSES):
    model.eval()
    total_loss, correct, total = 0.0, 0, 0
    class_correct = torch.zeros(num_classes)
    class_total   = torch.zeros(num_classes)

    with torch.no_grad():
        for images, labels in loader:
            images  = images.to(device)
            labels  = labels.to(device)
            outputs = model(images)
            loss    = criterion(outputs, labels)

            total_loss += loss.item()
            _, predicted = outputs.max(1)
            correct += predicted.eq(labels).sum().item()
            total   += labels.size(0)

            # ── Per-class accuracy tracking ──
            for c in range(num_classes):
                mask = labels == c
                class_correct[c] += \
                    predicted[mask].eq(labels[mask]).sum().item()
                class_total[c]   += mask.sum().item()

    per_class_acc = (
        class_correct / class_total.clamp(min=1)
    ).tolist()

    return (total_loss / len(loader),
            correct / total,
            per_class_acc)


