# STEP 3 — CELL 2 (REWRITTEN): HybridDatePalmModel with feature-map BCAF
# ============================================================

EFF_FEATURES  = 1280
SWIN_FEATURES = 768
FUSION_DIM    = 512
CONCAT_DIM    = FUSION_DIM * 2   # 1024

class HybridDatePalmModel(nn.Module):
    def __init__(self, num_classes=9):
        super().__init__()

        # Branch A: EfficientNetV2-S
        self.efficientnet = timm.create_model(
            'tf_efficientnetv2_s', pretrained=True, num_classes=0)

        # Branch B: Swin-Tiny
        self.swin = timm.create_model(
            'swin_tiny_patch4_window7_224', pretrained=True, num_classes=0)

        # Projections — now 1x1 convs to preserve spatial structure
        self.eff_proj = nn.Sequential(
            nn.Conv2d(EFF_FEATURES, FUSION_DIM, kernel_size=1),
            nn.BatchNorm2d(FUSION_DIM),
            nn.ReLU(),
            nn.Dropout2d(0.3)
        )
        self.swin_proj = nn.Sequential(
            nn.Conv2d(SWIN_FEATURES, FUSION_DIM, kernel_size=1),
            nn.BatchNorm2d(FUSION_DIM),
            nn.ReLU(),
            nn.Dropout2d(0.3)
        )

        # Bidirectional cross-attention (now operates on tokens)
        self.cross_attention = CrossAttention(
            dim=FUSION_DIM, num_heads=8, dropout=0.1)

        # Classifier head — unchanged
        self.classifier = nn.Sequential(
            nn.Linear(CONCAT_DIM, 512),
            nn.BatchNorm1d(512),
            nn.ReLU(),
            nn.Dropout(0.4),
            nn.Linear(512, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, num_classes)
        )

    def forward(self, x):
        # 1. Extract feature maps (skip pooling)
        e_map = self.efficientnet.forward_features(x)   # (B, 1280, 7, 7)
        s_map = self.swin.forward_features(x)           # (B, 7, 7, 768)
        s_map = s_map.permute(0, 3, 1, 2).contiguous()  # (B, 768, 7, 7)

        # 2. Project to common channel dim
        e_map = self.eff_proj(e_map)    # (B, 512, 7, 7)
        s_map = self.swin_proj(s_map)   # (B, 512, 7, 7)

        # 3. Flatten spatial → token sequence
        B, C, H, W = e_map.shape
        e_tokens = e_map.flatten(2).transpose(1, 2)   # (B, 49, 512)
        s_tokens = s_map.flatten(2).transpose(1, 2)   # (B, 49, 512)

        # 4. Bidirectional cross-attention
        fused_tokens = self.cross_attention(e_tokens, s_tokens)  # (B, 49, 1024)

        # 5. Pool over tokens for classifier
        fused_vec = fused_tokens.mean(dim=1)  # (B, 1024)

        return self.classifier(fused_vec)


