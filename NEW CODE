def attention_with_capture(q, k, v):
    B, N, _ = q.shape
    H = model.cross_attention.num_heads
    D = model.cross_attention.head_dim
    q_ = q.view(B, N, H, D).transpose(1, 2)
    k_ = k.view(B, N, H, D).transpose(1, 2)
    v_ = v.view(B, N, H, D).transpose(1, 2)
    attn = (q_ @ k_.transpose(-2, -1)) * model.cross_attention.scale
    attn = torch.softmax(attn, dim=-1)
    captured_attn['weights'] = attn.detach()
    out = attn @ v_
    return out.transpose(1, 2).reshape(B, N, H * D)

