class CrossAttention(nn.Module):
    """Real cross-attention on token sequences (Lesson 4 fix)."""
    def __init__(self, dim, num_heads=8, dropout=0.1):
        super().__init__()
        self.num_heads = num_heads
        self.head_dim  = dim // num_heads
        self.scale     = self.head_dim ** -0.5

        self.q_eff  = nn.Linear(dim, dim)
        self.k_swin = nn.Linear(dim, dim)
        self.v_swin = nn.Linear(dim, dim)
        self.q_swin = nn.Linear(dim, dim)
        self.k_eff  = nn.Linear(dim, dim)
        self.v_eff  = nn.Linear(dim, dim)

        self.out_proj = nn.Sequential(
            nn.Linear(dim*2, dim*2), nn.LayerNorm(dim*2),
            nn.GELU(), nn.Dropout(dropout))
        self.dropout = nn.Dropout(dropout)

    def attention(self, q, k, v):
        B, N, _ = q.shape
        H, D = self.num_heads, self.head_dim
        q = q.view(B, N, H, D).transpose(1, 2)
        k = k.view(B, N, H, D).transpose(1, 2)
        v = v.view(B, N, H, D).transpose(1, 2)
        attn = (q @ k.transpose(-2, -1)) * self.scale
        attn = self.dropout(torch.softmax(attn, dim=-1))
        out = attn @ v
        return out.transpose(1, 2).reshape(B, N, H * D)

    def forward(self, eff_tokens, swin_tokens):
        eff_attended  = self.attention(self.q_eff(eff_tokens),
            self.k_swin(swin_tokens), self.v_swin(swin_tokens))
        swin_attended = self.attention(self.q_swin(swin_tokens),
            self.k_eff(eff_tokens), self.v_eff(eff_tokens))
        return self.out_proj(torch.cat([eff_attended, swin_attended], dim=-1))


EFF_FEATURES, SWIN_FEATURES, FUSION_DIM = 1280, 768, 512
CONCAT_DIM = FUSION_DIM * 2

class HybridDatePalmModel(nn.Module):
    def __init__(self, num_classes=9):
        super().__init__()
        self.efficientnet = timm.create_model(
            'tf_efficientnetv2_s', pretrained=True, num_classes=0)
        self.swin = timm.create_model(
            'swin_tiny_patch4_window7_224', pretrained=True, num_classes=0)

        self.eff_proj = nn.Sequential(
            nn.Conv2d(EFF_FEATURES, FUSION_DIM, 1), nn.BatchNorm2d(FUSION_DIM),
            nn.ReLU(), nn.Dropout2d(0.3))
        self.swin_proj = nn.Sequential(
            nn.Conv2d(SWIN_FEATURES, FUSION_DIM, 1), nn.BatchNorm2d(FUSION_DIM),
            nn.ReLU(), nn.Dropout2d(0.3))

        self.cross_attention = CrossAttention(dim=FUSION_DIM, num_heads=8, dropout=0.1)

        self.classifier = nn.Sequential(
            nn.Linear(CONCAT_DIM, 512), nn.BatchNorm1d(512),
            nn.ReLU(), nn.Dropout(0.4),
            nn.Linear(512, 256), nn.ReLU(),
            nn.Dropout(0.3), nn.Linear(256, num_classes))

    def forward(self, x):
        e_map = self.efficientnet.forward_features(x)
        s_map = self.swin.forward_features(x)
        s_map = s_map.permute(0, 3, 1, 2).contiguous()
        e_map = self.eff_proj(e_map)
        s_map = self.swin_proj(s_map)
        B, C, H, W = e_map.shape
        e_tokens = e_map.flatten(2).transpose(1, 2)
        s_tokens = s_map.flatten(2).transpose(1, 2)
        fused_tokens = self.cross_attention(e_tokens, s_tokens)
        fused_vec = fused_tokens.mean(dim=1)
        return self.classifier(fused_vec)


