class CrossAttention(nn.Module):
    def __init__(self, dim, num_heads=8, dropout=0.1):
        super().__init__()
        self.num_heads = num_heads
        self.head_dim  = dim // num_heads
        self.scale     = self.head_dim ** -0.5
        self.q_eff     = nn.Linear(dim, dim)
        self.k_swin    = nn.Linear(dim, dim)
        self.v_swin    = nn.Linear(dim, dim)
        self.q_swin    = nn.Linear(dim, dim)
        self.k_eff     = nn.Linear(dim, dim)
        self.v_eff     = nn.Linear(dim, dim)
        self.out_proj  = nn.Sequential(
            nn.Linear(dim*2, dim*2),
            nn.LayerNorm(dim*2),
            nn.GELU(),
            nn.Dropout(dropout))
        self.dropout   = nn.Dropout(dropout)

    def attention(self, q, k, v):
        B, H, D = q.shape[0], self.num_heads, self.head_dim
        q = q.view(B, H, 1, D)
        k = k.view(B, H, 1, D)
        v = v.view(B, H, 1, D)
        attn = torch.matmul(
            q, k.transpose(-2,-1)) * self.scale
        attn = self.dropout(torch.softmax(attn, dim=-1))
        return torch.matmul(attn, v).view(B, H*D)

    def forward(self, eff_feat, swin_feat):
        eff_att  = self.attention(
            self.q_eff(eff_feat),
            self.k_swin(swin_feat),
            self.v_swin(swin_feat))
        swin_att = self.attention(
            self.q_swin(swin_feat),
            self.k_eff(eff_feat),
            self.v_eff(eff_feat))
        return self.out_proj(
            torch.cat([eff_att, swin_att], dim=1))


class HybridDatePalmModel(nn.Module):
    def __init__(self, num_classes=9):
        super().__init__()
        self.efficientnet = timm.create_model(
            'tf_efficientnetv2_s',
            pretrained=False, num_classes=0)
        self.swin = timm.create_model(
            'swin_tiny_patch4_window7_224',
            pretrained=False, num_classes=0)
        self.eff_proj = nn.Sequential(
            nn.Linear(1280,512), nn.BatchNorm1d(512),
            nn.ReLU(), nn.Dropout(0.3))
        self.swin_proj = nn.Sequential(
            nn.Linear(768,512), nn.BatchNorm1d(512),
            nn.ReLU(), nn.Dropout(0.3))
        self.cross_attention = CrossAttention(
            dim=512, num_heads=8, dropout=0.1)
        self.classifier = nn.Sequential(
            nn.Linear(1024,512), nn.BatchNorm1d(512),
            nn.ReLU(), nn.Dropout(0.4),
            nn.Linear(512,256), nn.ReLU(),
            nn.Dropout(0.3), nn.Linear(256,num_classes))

    def forward(self, x):
        e = self.eff_proj(self.efficientnet(x))
        s = self.swin_proj(self.swin(x))
        f = self.cross_attention(e, s)
        return self.classifier(f)


